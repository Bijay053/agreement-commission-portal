# Database
DATABASE_URL=postgresql://portal_user:your_password@db:5432/agreement_portal
DB_PASSWORD=your_secure_database_password

# Django
SESSION_SECRET=generate_a_strong_random_string_here
DEBUG=False
ALLOWED_HOSTS=portal.studyinfocentre.com
CORS_ORIGINS=https://portal.studyinfocentre.com

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=studyinfocentre-portal-documents
AWS_S3_REGION=ap-south-1

# SMTP (AWS SES)
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your_ses_smtp_username
SMTP_PASS=your_ses_smtp_password
FROM_EMAIL=noreply@studyinfocentre.com

# Redis
REDIS_URL=redis://redis:6379/0

# Sentry (optional)
SENTRY_DSN=

# PDF Download Password
PDF_DOWNLOAD_PASSWORD=Study@2o19
